# Get yours at https://platform.openai.com/api-keys
# NOTE: without this key set, /api/chat falls back to canned mock replies
# so you can still demo the UI without burning API credits.
OPENAI_API_KEY=sk-proj-replace-me

# Supabase project settings (create one at supabase.com, free tier OK)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-replace-me

# Used for absolute URLs in OG tags, can stay as localhost in dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000
